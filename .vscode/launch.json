      "args": [
        // "--help",
      ]
    },
    {
      "name": "run current javascript",
      "program": "${file}",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node"
    },
    {
      "name": "run current typescript",
      "program": "${file}",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "tsx"
    },
    {
      "name": "Jest all tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm exec jest --no-watch --testTimeout=60000"
    },
    {
      "name": "Jest single test",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm exec jest --no-watch --testTimeout=60000 dates.test"
    }
  ]
}
